{
  /* 
  This file is in love/data/.vscode/tasks.json
  Edit there
  Then run love_repo_initialize, which copies it here
  */
  "version": "2.0.0",
  "tasks": [
    /*
    Server, Watcher, Webpack Watcher and Git Push Auto used to start here.
    They now run as systemd user units, created and started by daemons_ensure.
    Two owners would mean two of each racing over the same port and bundles,
    so they are deliberately absent — only interactive things belong here.
    */
    {
      "label": "Terminal",
      "type": "shell",
      "command": "cd love && bash scripts/p.sh",
      "runOptions": {
        "runOn": "folderOpen"
      },
    }
  ]
}