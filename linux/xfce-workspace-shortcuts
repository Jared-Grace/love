#!/usr/bin/env bash
# Ensure at least 10 XFCE workspaces, and wire the workspace keys to them:
#   Super+1..9,0        -> switch to workspace 1..10
#   Shift+Super+1..9,0  -> move the active window to workspace 1..10
#   Super+Left/Right    -> previous / next workspace (wraps at the ends)
#   Ctrl+Alt+Left/Right -> previous / next workspace (wraps at the ends)
#
# Why command shortcuts (wmctrl) instead of xfwm4's built-in workspace keys:
# xfwm4's own /xfwm4/ keyboard grabs proved fragile here -- after a hibernate
# (and a live workspace-count change) they stopped firing, and neither
# `xfwm4 --replace` nor re-writing the bindings revived them. The /commands/
# shortcuts are grabbed by a different daemon (xfsettingsd), which kept working
# across the same hibernate. So we route through xfsettingsd + wmctrl for
# durability. Requires: wmctrl (apt install wmctrl).
#
# Idempotent: re-running changes nothing. Never reduces an existing higher count.
set -euo pipefail

readonly MINIMUM_WORKSPACES=10
readonly DIGITS="1 2 3 4 5 6 7 8 9 0"
readonly KB=xfce4-keyboard-shortcuts

# Absolute path to the prev/next helper that sits beside this script in the repo.
# xfsettingsd runs command shortcuts with no useful PATH, and the ~/.local/bin
# symlink dir holds only THIS script -- so the shortcut must name the helper by
# full path. readlink -f resolves the invoking symlink back to the real repo
# file, whose directory also contains workspace-switch.
readonly WORKSPACE_SWITCH="$(dirname "$(readlink -f "$0")")/workspace-switch"

require_wmctrl() {
  if ! command -v wmctrl >/dev/null 2>&1; then
    echo "error: wmctrl not found -- install it with:  sudo apt install -y wmctrl" >&2
    exit 1
  fi
}

workspace_count_get() {
  xfconf-query -c xfwm4 -p /general/workspace_count
}

workspace_count_ensure_minimum() {
  local current
  current=$(workspace_count_get)
  if [ "$current" -lt "$MINIMUM_WORKSPACES" ]; then
    xfconf-query -c xfwm4 -p /general/workspace_count -s "$MINIMUM_WORKSPACES"
  fi
}

# command_shortcut_set <accelerator> <command>
# Creates the /commands/custom property if absent, overwrites it if present.
command_shortcut_set() {
  local path="/commands/custom/$1" command=$2
  if xfconf-query -c "$KB" -p "$path" >/dev/null 2>&1; then
    xfconf-query -c "$KB" -p "$path" -s "$command"
  else
    xfconf-query -c "$KB" -p "$path" -n -t string -s "$command"
  fi
}

# Remove any stale xfwm4-native digit binding this script used to create, so a
# single daemon (xfsettingsd) owns each accelerator -- no double-grab if xfwm4
# ever starts honoring them again.
xfwm4_digit_binding_remove() {
  xfconf-query -c "$KB" -p "/xfwm4/custom/$1" -r 2>/dev/null || true
}

digits_wire_to_workspaces() {
  local digit index=0
  for digit in $DIGITS; do
    xfwm4_digit_binding_remove "<Super>${digit}"
    xfwm4_digit_binding_remove "<Shift><Super>${digit}"
    command_shortcut_set "<Super>${digit}" "wmctrl -s ${index}"
    command_shortcut_set "<Shift><Super>${digit}" "wmctrl -r :ACTIVE: -t ${index}"
    index=$((index + 1))
  done
}

# Disable an xfwm4-native shortcut by writing an empty custom value. Unlike -r
# (which reverts to any /xfwm4/default action, leaving the grab alive), an empty
# override tells xfwm4 "no action" -- freeing the accelerator for xfsettingsd to
# grab as a command shortcut. This is exactly what the Settings GUI's "Clear"
# does. Idempotent: creating vs overwriting the same empty string is a no-op.
xfwm4_shortcut_disable() {
  local path="/xfwm4/custom/$1"
  if xfconf-query -c "$KB" -p "$path" >/dev/null 2>&1; then
    xfconf-query -c "$KB" -p "$path" -s ""
  else
    xfconf-query -c "$KB" -p "$path" -n -t string -s ""
  fi
}

# Wire the arrow-key prev/next switchers through the same durable command-shortcut
# path as the digits. Super+Left/Right and Ctrl+Alt+Left/Right were xfwm4-native
# (fragile across hibernate); disable them there and rebind via wmctrl.
arrows_wire_to_workspaces() {
  local accel
  for accel in "<Super>Left" "<Super>Right" "<Primary><Alt>Left" "<Primary><Alt>Right"; do
    xfwm4_shortcut_disable "$accel"
  done
  command_shortcut_set "<Super>Left"          "${WORKSPACE_SWITCH} prev"
  command_shortcut_set "<Super>Right"         "${WORKSPACE_SWITCH} next"
  command_shortcut_set "<Primary><Alt>Left"   "${WORKSPACE_SWITCH} prev"
  command_shortcut_set "<Primary><Alt>Right"  "${WORKSPACE_SWITCH} next"
}

require_wmctrl
workspace_count_ensure_minimum
digits_wire_to_workspaces
arrows_wire_to_workspaces
echo "OK: $(workspace_count_get) workspaces; Super+1..9,0 & Shift+Super+1..9,0 wired;" \
     "Super+Left/Right & Ctrl+Alt+Left/Right switch prev/next."
