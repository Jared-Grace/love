{
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(cat:*)",
      "Bash(cp:*)",
      "Bash(cd:*)",
      "Bash(diff:*)",
      "Bash(echo:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(which:*)",
      "Bash(df:*)",
      "Bash(ps:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(ls:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(node --check:*)",
      "Bash(node scripts/g.mjs ai)",
      "Write(/tmp/claude-1000/-home-j-repos-love/**)",
      "Edit(/tmp/claude-1000/-home-j-repos-love/**)",
      "Read(/tmp/claude-1000/-home-j-repos-love/**)",
      "Bash(mkdir /tmp/claude-1000/-home-j-repos-love/:*)",
      "Bash(mkdir -p /tmp/claude-1000/-home-j-repos-love/:*)",
      "Bash(rm /tmp/claude-1000/-home-j-repos-love/:*)",
      "Bash(rm -r /tmp/claude-1000/-home-j-repos-love/:*)",
      "Bash(rm -rf /tmp/claude-1000/-home-j-repos-love/:*)",
      "Bash(mv /tmp/claude-1000/-home-j-repos-love/:*)",
      "Edit(.claude/hooks/bash-command-guard.py)",
      "Write(.claude/hooks/bash-command-guard.py)",
      "Edit(.claude/hooks/lock_claude_acquire.mjs)",
      "Write(.claude/hooks/lock_claude_acquire.mjs)",
      "Edit(.claude/hooks/lock_claude_daemon.mjs)",
      "Write(.claude/hooks/lock_claude_daemon.mjs)",
      "Edit(.claude/hooks/lock_claude_release.mjs)",
      "Write(.claude/hooks/lock_claude_release.mjs)"
    ],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/j/repos/love/.claude/hooks/bash-command-guard.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node /home/j/repos/love/.claude/hooks/lock_claude_acquire.mjs",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node /home/j/repos/love/.claude/hooks/lock_claude_release.mjs",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
